{
  "name": "colors-lamp",
  "version": "1.0.0",
  "description": "This project is a full-stack LAMP application built as part of my COP 4331 coursework. The app allows users to securely log in and manage a personal collection of colors. Saved colors live in a remote database and stay accessible across sessions.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
  "lint:js": "eslint \"public/**/*.js\"",
  "lint:css": "stylelint \"public/**/*.css\"",
  "lint:html": "htmlhint \"public/**/*.html\"",
  "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
  "fix": "eslint \"public/**/*.js\" --fix && stylelint \"public/**/*.css\" --fix",
  "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielJEfres/colors-lamp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/DanielJEfres/colors-lamp/issues"
  },
  "homepage": "https://github.com/DanielJEfres/colors-lamp#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "htmlhint": "^1.9.2",
    "jest": "^30.3.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
